### =========================================
### QUIZ SUBMIT - NOVICE
### =========================================

POST http://127.0.0.1:8000/api/v1/quiz/submit/
Content-Type: application/json

{
  "experience": "novice",
  "play_style": "field",
  "priority": "reliability",
  "budget": "medium",
  "maintenance": "no",
  "weight": "important",
  "simple_start": "yes"
}

###

### =========================================
### QUIZ SUBMIT - MILSIM
### =========================================

POST http://127.0.0.1:8000/api/v1/quiz/submit/
Content-Type: application/json

{
  "experience": "few_games",
  "play_style": "milsim",
  "priority": "realism",
  "budget": "high",
  "maintenance": "yes",
  "weight": "not_important",
  "simple_start": "no"
}

